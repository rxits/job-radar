# Copy to .env.local and fill from your Supabase project (Settings → API).
# .env.local is gitignored — never commit real keys.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Secret shared between Vercel Cron and the cron route (any long random string).
CRON_SECRET=

# Only needed if using the app-level AES fallback instead of Supabase Vault:
# APP_ENCRYPTION_KEY=
